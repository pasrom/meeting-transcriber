{
  "name": "Stable tag protection",
  "target": "tag",
  "enforcement": "active",
  "conditions": {
    "ref_name": {
      "include": ["refs/tags/v*"],
      "exclude": ["refs/tags/*-*"]
    }
  },
  "rules": [
    {
      "type": "required_status_checks",
      "parameters": {
        "strict_required_status_checks_policy": false,
        "required_status_checks": [
          { "context": "lint" },
          { "context": "analyze" },
          { "context": "test (homebrew)" },
          { "context": "test (appstore)" },
          { "context": "test (tsan)" },
          { "context": "test (asan)" },
          { "context": "quality-baseline" },
          { "context": "e2e" },
          { "context": "e2e-app" }
        ]
      }
    }
  ]
}
